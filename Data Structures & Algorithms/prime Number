#include<iostream>
#include<cmath>
using namespace std;
void isprime(int n){
    if(n==1)  return ;
    for(int i=2;i<=sqrt(n);i++){
        if(n%i==0) {
            cout<<"Not prime";
            return;
        }
    }
    cout<<"Number is prime";
}
int main(){
    isprime(4);
}
